# Banco local: pnpm db:up (docker-compose) e use a URL abaixo.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aparatus"
REDIS_URL="redis://localhost:6379"

BETTER_AUTH_SECRET="secret"
# lvh.me (não localhost) — cookies de sessão com Domain=crossSubDomainCookies
# não são compartilhados de forma confiável entre subdomínios de "localhost"
# puro (hostname de um único label, sem ponto) em nenhum cliente HTTP
# testado; lvh.me resolve *.lvh.me para 127.0.0.1 sem editar hosts file e
# se comporta como produção (domínio real) nesse aspecto.
# Exceção conhecida: roteadores com proteção DNS-rebind (ex.: Fritz!Box)
# bloqueiam domínios públicos que resolvem para IP privado e devolvem
# NXDOMAIN para *.lvh.me. Fix: `pnpm dev:hosts add <slug>` (escreve no hosts
# do Windows, ignora DNS) ou adicionar lvh.me às exceções de rebind do roteador.
BETTER_AUTH_URL=http://lvh.me:3000

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Billing SaaS (assinatura dos estabelecimentos)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_BILLING_WEBHOOK_SECRET=""
STRIPE_CONNECT_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_GROWTH_MONTHLY=""
STRIPE_PRICE_PRO_MONTHLY=""
# Testar /onboarding sem clicar no Checkout hospedado: com chave sk_test_ e
# NODE_ENV != production, `pnpm dev:test-checkout` cria uma Subscription real
# de teste e imprime uma URL com session_id=devbypass_<id> — nunca funciona
# com chave sk_live_ ou em produção (lib/services/subscription-claim-service.ts).

NEXT_PUBLIC_APP_URL="http://lvh.me:3000"
# Domínio raiz para subdomínios de tenant ({slug}.NEXT_PUBLIC_ROOT_DOMAIN)
NEXT_PUBLIC_ROOT_DOMAIN="lvh.me:3000"

# Upload de fotos de serviços (Cloudinary) — sem as três, o endpoint de
# upload responde 503 e o formulário de serviço só bloqueia o campo de
# imagem (app/api/media/upload/route.ts). Valores de exemplo no formato do
# painel Cloudinary (Dashboard > Product Environment Credentials).
CLOUDINARY_CLOUD_NAME="my-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="AbCdEfGhIjKlMnOpQrStUvWxYz1"
# Mesmas credenciais acima em formato de URL única (painel Cloudinary >
# API Environment variable) — só referência, o código atual lê as três
# variáveis separadas acima, não esta.
CLOUDINARY_URL="cloudinary://123456789012345:AbCdEfGhIjKlMnOpQrStUvWxYz1@my-cloud-name"

# E-mail transacional (Resend) e worker de lembretes (BullMQ/Redis)
RESEND_API_KEY=""
EMAIL_FROM="Bladiq <bookings@bladiq.com>"

# IA (Fase 6 — chatbot fora do MVP)
OPENAI_API_KEY=""
